# Android
# Ignore the following files and directories from your Android project.
/android/app/build/
/android/build/
/android/.gradle/
/android/key.properties
/android/local.properties
/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# iOS
# Ignore the following files and directories from your iOS project.
/ios/Pods/
/ios/Carthage/
/ios/Flutter/App.framework
/ios/Flutter/Debug.xcconfig
/ios/Flutter/Release.xcconfig
/ios/Runner/GeneratedPluginRegistrant.*
/ios/Runner/GoogleService-Info.plist
/ios/.symlinks/

# macOS
# Ignore the following files and directories from your macOS project.
/macos/Pods/
/macos/Carthage/
/macos/Flutter/ephemeral/
/macos/Runner/GoogleService-Info.plist

# Windows
/windows/flutter/ephemeral/
/windows/runner/Debug/
/windows/runner/Profile/
/windows/runner/Release/