platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Patch flutter_contacts to work with UIScene lifecycle.
  # The plugin force-unwraps UIApplication.shared.delegate!.window!! which is nil
  # when UIApplicationSceneManifest is present. Replace with UIScene-compatible lookup.
  contacts_plugin_path = File.join(
    installer.sandbox.root,
    'flutter_contacts',
    'ios',
    'Classes',
    'SwiftFlutterContactsPlugin.swift'
  )
  if File.exist?(contacts_plugin_path)
    content = File.read(contacts_plugin_path)
    old_line = 'let rootViewController = UIApplication.shared.delegate!.window!!.rootViewController!'
    new_line = <<~SWIFT
      let rootViewController: UIViewController
              let keyWindow = UIApplication.shared.connectedScenes
                .compactMap { $0 as? UIWindowScene }
                .flatMap { $0.windows }
                .first(where: { $0.isKeyWindow })
              if let rvc = keyWindow?.rootViewController {
                rootViewController = rvc
              } else if let rvc = UIApplication.shared.delegate?.window??.rootViewController {
                rootViewController = rvc
              } else {
                rootViewController = UIViewController()
              }
    SWIFT
    if content.include?(old_line)
      patched = content.gsub(old_line, new_line.strip)
      File.write(contacts_plugin_path, patched)
      puts "✅ Patched flutter_contacts for UIScene compatibility"
    end
  end
end
