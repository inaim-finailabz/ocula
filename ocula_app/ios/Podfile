platform :ios, '16.4'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.4'
      # Exclude x86_64 from device builds to prevent App Store rejection
      # for pre-built pods that carry simulator slices (e.g. objective_c.framework).
      config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'x86_64'
    end
  end

  # flutter_llama links llama.framework dynamically; embed correct slice from local plugin.
  llama_xcfw = File.expand_path(
    '../plugins/flutter_llama/ios/llama.xcframework',
    File.dirname(__FILE__)
  )
  Dir.glob(File.join(installer.sandbox.root,
                     'Target Support Files', 'Pods-Runner',
                     'Pods-Runner-frameworks.sh')).each do |script|
    content = File.read(script)
    patch = <<~BASH

      # flutter_llama patch: embed llama.framework from xcframework
      LLAMA_XCFW="#{llama_xcfw}"
      if [[ "$PLATFORM_NAME" == *"simulator"* ]]; then
        install_framework "$LLAMA_XCFW/ios-arm64_x86_64-simulator/llama.framework"
      else
        install_framework "$LLAMA_XCFW/ios-arm64/llama.framework"
      fi
    BASH
    content.gsub!(/\n\n\s*# flutter_llama patch:.*?fi\n/m, '')
    content.gsub!(
      /([ \t]+install_framework[^\n]*flutter_llama\.framework")/,
      "\\1#{patch}"
    )
    File.write(script, content)
    puts "patched Pods-Runner-frameworks.sh: llama.xcframework embedded"
  end

  # Patch speech_to_text: add locale fallback so SFSpeechRecognizer never returns nil.
  # On iOS 26 beta the locale identifier format changed, causing SFSpeechRecognizer(locale:)
  # to return nil for the current locale, making initialize() return false.
  # speech_to_text uses source.path = "." pointing to the pub-cache.
  stt_plugin_path = File.expand_path(
    File.join(ENV['HOME'], '.pub-cache', 'hosted', 'pub.dev',
              'speech_to_text-7.3.0', 'darwin', 'speech_to_text',
              'Sources', 'speech_to_text', 'SpeechToTextPlugin.swift')
  )
  if File.exist?(stt_plugin_path)
    content = File.read(stt_plugin_path)
    old_recognizer = '    recognizer = SFSpeechRecognizer(locale: locale)'
    new_recognizer = <<~SWIFT
          recognizer = SFSpeechRecognizer(locale: locale)
              // Fallback: if locale is unsupported (iOS 26 beta locale format changes),
              // try common en-US fallbacks so initialize() does not silently return false.
              if recognizer == nil {
                let fallbacks: [Locale] = [
                  Locale(identifier: "en-US"),
                  Locale(identifier: "en_US"),
                  Locale(identifier: "en"),
                ]
                for fb in fallbacks {
                  recognizer = SFSpeechRecognizer(locale: fb)
                  if recognizer != nil { break }
                }
              }
    SWIFT
    if content.include?(old_recognizer) && !content.include?('Fallback: if locale is unsupported')
      patched = content.gsub(old_recognizer, new_recognizer.rstrip)
      File.write(stt_plugin_path, patched)
      puts "✅ Patched speech_to_text: locale fallback for iOS 26 compatibility"
    else
      puts "ℹ️  speech_to_text patch already applied or pattern not found"
    end
  else
    puts "⚠️  speech_to_text plugin not found at #{stt_plugin_path}"
  end

  # Patch flutter_contacts to work with UIScene lifecycle.
  # The plugin force-unwraps UIApplication.shared.delegate!.window!! which is nil
  # when UIApplicationSceneManifest is present. Replace with UIScene-compatible lookup.
  contacts_plugin_path = File.join(
    installer.sandbox.root,
    'flutter_contacts',
    'ios',
    'Classes',
    'SwiftFlutterContactsPlugin.swift'
  )
  if File.exist?(contacts_plugin_path)
    content = File.read(contacts_plugin_path)
    old_line = 'let rootViewController = UIApplication.shared.delegate!.window!!.rootViewController!'
    new_line = <<~SWIFT
      let rootViewController: UIViewController
              let keyWindow = UIApplication.shared.connectedScenes
                .compactMap { $0 as? UIWindowScene }
                .flatMap { $0.windows }
                .first(where: { $0.isKeyWindow })
              if let rvc = keyWindow?.rootViewController {
                rootViewController = rvc
              } else if let rvc = UIApplication.shared.delegate?.window??.rootViewController {
                rootViewController = rvc
              } else {
                rootViewController = UIViewController()
              }
    SWIFT
    if content.include?(old_line)
      patched = content.gsub(old_line, new_line.strip)
      File.write(contacts_plugin_path, patched)
      puts "✅ Patched flutter_contacts for UIScene compatibility"
    end
  end
end
