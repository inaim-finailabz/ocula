default_platform(:ios)

def asc_api_key
  key_id    = ENV["ASC_KEY_ID"].to_s.empty?    ? "HD448CU9S4" : ENV["ASC_KEY_ID"]
  issuer_id = ENV["ASC_ISSUER_ID"].to_s.empty? ? "69a6de77-57dd-47e3-e053-5b8c7c11a4d1" : ENV["ASC_ISSUER_ID"]

  if ENV["ASC_KEY_CONTENT"] && !ENV["ASC_KEY_CONTENT"].empty?
    app_store_connect_api_key(
      key_id:                  key_id,
      issuer_id:               issuer_id,
      key_content:             ENV["ASC_KEY_CONTENT"],
      is_key_content_base64:   true
    )
  else
    local_key = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
    UI.user_error!("Key file not found: #{local_key}") unless File.exist?(local_key)
    app_store_connect_api_key(
      key_id:       key_id,
      issuer_id:    issuer_id,
      key_filepath: local_key
    )
  end
end

platform :ios do

  desc "Build IPA and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = asc_api_key

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "Runner.xcodeproj"
    )

    if ENV["CI"]
      get_certificates(
        api_key:     api_key,
        output_path: "/tmp/certs",
        force:       false
      )
      get_provisioning_profile(
        api_key:        api_key,
        app_identifier: "com.finailabz.ocula",
        output_path:    "/tmp/profiles",
        readonly:       false
      )
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id:               "AA6PZ62FPQ",
        bundle_identifier:     "com.finailabz.ocula",
        code_sign_identity:    "iPhone Distribution",
        profile_uuid:          ENV["sigh_com.finailabz.ocula_appstore_profile-uuid"] || ENV["sigh_com.finailabz.ocula_appstore-uuid"]
      )
    end

    # Run outside bundle exec to avoid CocoaPods/Bundler collision.
    system("export PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\" && cd #{File.expand_path("../..")} && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist") \
      or UI.user_error!("flutter build ipa failed")

    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "../build/ios/ipa/ocula_app.ipa",
      skip_waiting_for_build_processing: true,
      changelog:                         "Ocula beta"
    )
  end

  error do |lane, exception|
    puts "Lane #{lane} failed: #{exception.message}"
  end

end
